# =============================================================================
# AgentLabX — example environment variables
# =============================================================================
# Copy to `.env` and fill in the values you need. The process picks this file
# up automatically (pydantic-settings + LiteLLM). `.env` is gitignored.
#
# Only the provider key for the model you use is REQUIRED; the others can
# stay empty. For a zero-cost smoke test, run `agentlabx serve --mock-llm`
# and none of these keys are needed.
# =============================================================================


# -----------------------------------------------------------------------------
# LLM provider keys (one of these is needed unless --mock-llm is used)
# LiteLLM reads these directly — no wrapping code in AgentLabX.
# -----------------------------------------------------------------------------

# OpenAI (gpt-5*, gpt-4*, o3*, o1-mini, etc.)
OPENAI_API_KEY=

# Anthropic (claude-sonnet-4-6, claude-opus-4-6, claude-haiku-4-5-20251001, ...)
ANTHROPIC_API_KEY=

# Google Gemini (gemini-2.5-pro, gemini-2.0-flash, ...)
GEMINI_API_KEY=

# DeepSeek (deepseek-chat, deepseek-coder)
DEEPSEEK_API_KEY=


# -----------------------------------------------------------------------------
# Research tools
# -----------------------------------------------------------------------------

# GitHub code search (PyGithub). Optional — without a token you get anonymous
# rate limits (60 req/hr) which will exhaust quickly on any real run.
# Create at https://github.com/settings/tokens (no scopes required for public
# code search).
GITHUB_TOKEN=


# -----------------------------------------------------------------------------
# AgentLabX settings (pydantic-settings; env > YAML > defaults)
# Nested fields use `__` as a separator: section__field.
# All AGENTLABX_* are optional; defaults live in config/default.yaml.
# -----------------------------------------------------------------------------

# Server bind
# AGENTLABX_SERVER__HOST=0.0.0.0
# AGENTLABX_SERVER__PORT=8000
# AGENTLABX_SERVER__CORS_ORIGINS=["http://localhost:5173"]

# LLM defaults (session create-body can override per-session)
# AGENTLABX_LLM__DEFAULT_MODEL=claude-sonnet-4-6
# AGENTLABX_LLM__TEMPERATURE=0.0
# AGENTLABX_LLM__MAX_RETRIES=3
# AGENTLABX_LLM__COST_CEILING=10.00

# Storage — SQLite file + artifact directory. Async SQLite needs the `+aiosqlite`
# dialect; relative paths are resolved from the working directory.
# AGENTLABX_STORAGE__DATABASE_URL=sqlite+aiosqlite:///data/agentlabx.db
# AGENTLABX_STORAGE__ARTIFACTS_PATH=./data/artifacts

# Budget policy — share of LLM.COST_CEILING at which each tier fires.
# warning <= critical <= hard_ceiling (validator enforces ordering).
# AGENTLABX_BUDGET_POLICY__WARNING_THRESHOLD=0.7
# AGENTLABX_BUDGET_POLICY__CRITICAL_THRESHOLD=0.9
# AGENTLABX_BUDGET_POLICY__HARD_CEILING=1.0

# Execution backend — subprocess is the only implementation today; docker is
# planned in a later phase.
# AGENTLABX_EXECUTION__BACKEND=subprocess
# AGENTLABX_EXECUTION__TIMEOUT=120
# AGENTLABX_EXECUTION__MEMORY_LIMIT=4g

# Lab meeting triggers — when the PI agent convenes a multi-agent discussion.
# AGENTLABX_LAB_MEETING__ENABLED=true
# AGENTLABX_LAB_MEETING__TRIGGERS__CONSECUTIVE_FAILURES=3
# AGENTLABX_LAB_MEETING__TRIGGERS__SCORE_PLATEAU_ROUNDS=2
