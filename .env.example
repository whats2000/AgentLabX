# =============================================================================
# AgentLabX — environment variables for testing
# =============================================================================
# Copy to `.env` and fill in at least one API key + model. `.env` is gitignored.
#
# pytest-dotenv auto-loads `.env` before test collection, so real-LLM
# integration tests (`pytest -m real_llm`) pick up keys automatically.
#
# For normal usage, add your keys via the web UI (Settings > Credentials).
# They are stored encrypted per-user in the database — not in env vars.
# =============================================================================


# ---------------------------------------------------------------------------
# Real-LLM test config (at least one provider needed for `pytest -m real_llm`)
#
# Set the key AND model for the provider you want to test with.
# Model IDs use LiteLLM format: https://docs.litellm.ai/docs/providers
# ---------------------------------------------------------------------------

# The model to use for real-LLM tests. Pick the cheapest/fastest model
# available from your provider to keep test costs minimal.
TEST_LLM_MODEL=

# Provider keys — fill in the one that matches your TEST_LLM_MODEL.

# Anthropic (claude-sonnet-4-6, claude-opus-4-6, claude-haiku-4-5-20251001)
ANTHROPIC_API_KEY=
# TEST_LLM_MODEL=claude-haiku-4-5-20251001

# OpenAI (openai/gpt-5*, openai/gpt-4*, ...)
OPENAI_API_KEY=
# TEST_LLM_MODEL=openai/gpt-4o-mini

# Google Gemini (gemini/gemini-3.1-pro-preview, gemini/gemini-3.1-flash-lite-preview)
GEMINI_API_KEY=
# TEST_LLM_MODEL=gemini/gemini-3.1-flash-lite-preview

# DeepSeek (deepseek/deepseek-chat, deepseek/deepseek-reasoner)
DEEPSEEK_API_KEY=
# TEST_LLM_MODEL=deepseek/deepseek-chat


# ---------------------------------------------------------------------------
# MCP bundle slot values (admin-scope; AGENTLABX_SLOT_<UPPER>)
#
# The SlotResolver looks these up at MCP-server start time when a bundle
# declares an env_slot_ref. Setting the value here flips the bundle from
# `enabled=0` to `enabled=1` on the next dev-server restart.
# ---------------------------------------------------------------------------

# Semantic Scholar API key — required by the `semantic_scholar` MCP bundle.
# Get a key at https://www.semanticscholar.org/product/api#api-key-form
AGENTLABX_SLOT_SEMANTIC_SCHOLAR_API_KEY=
